{
  "name": "SymbolMobileWallet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "react-native start",
    "build:js": "react-native bundle --entry-file index.js --bundle-output ./bundle.js",
    "build:android:dev": "react-native run-android",
    "build:android:prod": "cd ./android && ./gradlew assembleRelease",
    "build:ios:dev": "react-native run-ios",
    "build:ios:prod": "react-native run-ios --mode Release",
    "connect:android": "adb reverse tcp:8081 tcp:8081",
    "test": "jest",
    "test:cov": "c8 --reporter=lcov --reporter=text --report-dir=coverage npm run test",
    "test:cov:ci": "NODE_OPTIONS='--max-old-space-size=4096' c8 --reporter=lcov --reporter=text --report-dir=coverage npm run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix --color",
    "postinstall": "npx resolve-local-dependencies"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/native": "^7.1.24",
    "@react-navigation/native-stack": "^7.8.5",
    "bip39": "^3.1.0",
    "crypto-js": "^4.2.0",
    "events": "^3.3.0",
    "i18n-js": "^4.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "qrcode": "^1.5.4",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-crypto": "^2.2.0",
    "react-native-draggable-flatlist": "^4.0.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "^2.29.1",
    "react-native-keychain": "^8.1.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-permissions": "^3.6.1",
    "react-native-reanimated": "^4.2.0",
    "react-native-reorderable-list": "^0.18.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.18.0",
    "react-native-smooth-slider": "^1.3.6",
    "react-native-splash-screen": "^3.3.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "^0.7.1",
    "symbol-crypto-wasm-web": "^0.1.1",
    "symbol-sdk": "3.3.0",
    "wallet-common-core": "file:../../common/core",
    "wallet-common-ethereum": "file:../../common/ethereum",
    "wallet-common-symbol": "file:../../common/symbol"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@sinonjs/text-encoding": "^0.7.3",
    "@testing-library/react-native": "^13.3.3",
    "assert": "^2.1.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "c8": "^10.1.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-react": "^7.37.4",
    "jest": "^30.2.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "react-native-randombytes": "^3.6.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-test-renderer": "19.1.1",
    "resolve-local-dependencies": "^1.0.2",
    "rn-nodeify": "^10.3.0",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "d3-color": "3.1.0",
    "semver": "7.5.3",
    "react-native-vector-icons": "10.2.0"
  }
}
